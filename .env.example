# ──────────────────────────────────────────────────────────
# Baba Flats — Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# Do NOT commit .env to version control — it may contain secrets.

# ╔═══════════════════════════════════════════════════════╗
# ║  Client (Vite — prefixed with VITE_)                 ║
# ╚═══════════════════════════════════════════════════════╝

# Base URL of the API server the frontend talks to.
# In development this is typically the local Express server.
VITE_API_ORIGIN=http://localhost:8787

# Studio editor password (must match STUDIO_PASSWORD below).
# Required for the Studio UI to function — leave empty to see a config error.
VITE_STUDIO_PASSWORD=changeme

# Timeout (in milliseconds) for API requests made by the frontend.
VITE_API_TIMEOUT_MS=10000

# ╔═══════════════════════════════════════════════════════╗
# ║  Server (Express)                                    ║
# ╚═══════════════════════════════════════════════════════╝

# Port the API server listens on.
API_PORT=8787

# Studio editor password — REQUIRED. The server will refuse to start without it.
# Must match VITE_STUDIO_PASSWORD so the client can authenticate.
STUDIO_PASSWORD=changeme

# Node environment. Set to "production" in deployed environments
# to hide verbose error details in API responses.
# NODE_ENV=production

# ╔═══════════════════════════════════════════════════════╗
# ║  SMTP (server-side email for the contact form)       ║
# ╚═══════════════════════════════════════════════════════╝

# Hostname of the SMTP server (e.g., smtp.gmail.com, smtp.sendgrid.net).
SMTP_HOST=

# SMTP port. Common values: 587 (STARTTLS), 465 (SSL), 25 (unencrypted).
SMTP_PORT=587

# Use a direct TLS connection (port 465). Set to "true" or "false".
SMTP_SECURE=false

# SMTP authentication credentials.
SMTP_USER=
SMTP_PASS=

# "From" address shown on outgoing emails (e.g., noreply@example.com).
SMTP_FROM=

# Recipient address for contact-form submissions (e.g., hello@example.com).
SMTP_TO=
